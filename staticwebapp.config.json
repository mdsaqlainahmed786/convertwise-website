{
  "routes": [
    {
      "route": "/*",
      "redirect": "https://www.convertwise.site/:splat",
      "statusCode": 301,
      "conditions": {
        "host": ["convertwise.site"]
      }
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "/*.css",
      "/*.js",
      "/*.mjs",
      "/*.map",
      "/*.json",
      "/*.ico",
      "/*.png",
      "/*.jpg",
      "/*.jpeg",
      "/*.gif",
      "/*.svg",
      "/*.webp",
      "/*.txt",
      "/*.xml"
    ]
  }
}